<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C0B09">

    <!-- ── Main content ── -->
    <ScrollView
        android:id="@+id/sv_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_logo"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Gold Widget Pro"
                android:textColor="#FFD700"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Not connected"
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Account info (shown only when connected) -->
            <LinearLayout
                android:id="@+id/ll_account_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1C1A16"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_broker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_account_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

            </LinearLayout>

            <Button
                android:id="@+id/btn_connect"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Connect cTrader Account"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#FFD700"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_disconnect"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Disconnect"
                android:textColor="#F07070"
                android:textSize="15sp"
                android:backgroundTint="#1C0808"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_test_trades"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Test Trade Fetch"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:backgroundTint="#1A2A1A"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_trade_debug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#20FFD700"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How it works"
                android:textColor="#FFD700"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Tap &#34;Connect cTrader Account&#34; and log in with your cTrader credentials.\n\n2. Long-press your home screen and add a widget:\n   • Gold Simple (2×2) — price + day change\n   • Gold Detailed (4×2) — price + day stats\n   • Gold + Trade (4×3) — price + open position\n   • Gold P&amp;L (2×2) — price + P&amp;L with SL/TP colour\n\n3. Widgets refresh automatically every 5 minutes and on every screen wake. They show:\n   • Live XAUUSD spot price\n   • Day high / low / open / prev close\n   • Your open XAUUSD position (side, lots, entry, P&amp;L)\n\n4. Tap the refresh icon on any widget for an instant update."
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Note: P&amp;L is estimated (1 lot = 100 oz). Exact value depends on your broker&#39;s contract specification."
                android:textColor="#50FFFFFF"
                android:textSize="11sp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ── OAuth WebView (shown during login, hidden otherwise) ── -->
    <LinearLayout
        android:id="@+id/ll_oauth"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Top bar with Cancel button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1C1A16"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Connect cTrader Account"
                android:textColor="#FFD700"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_cancel_oauth"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Cancel"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:backgroundTint="#2A2824" />

        </LinearLayout>

        <WebView
            android:id="@+id/wv_oauth"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</FrameLayout>
