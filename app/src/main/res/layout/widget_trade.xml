<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header: GOLD left, pause + pill right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GOLD"
            android:textColor="#FFD700"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_market_closed"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_pause"
            android:visibility="gone"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tv_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/price_up"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/pill_up"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <!-- Price -->
    <TextView
        android:id="@+id/tv_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <!-- Hairline divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#30FFD700"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="4dp" />

    <!-- Day stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HIGH" android:textColor="#60FFD700" android:textSize="7sp" />
            <TextView android:id="@+id/tv_high" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/price_up" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOW" android:textColor="#60FFD700" android:textSize="7sp" />
            <TextView android:id="@+id/tv_low" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/price_down" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OPEN" android:textColor="#60FFD700" android:textSize="7sp" />
            <TextView android:id="@+id/tv_open" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#CCCCCC" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PREV" android:textColor="#60FFD700" android:textSize="7sp" />
            <TextView android:id="@+id/tv_prev_close" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#CCCCCC" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider before trade section -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20FFD700"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="4dp" />

    <!-- TRADE SECTION: spacer fills remaining height so trade sits above footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Active trade info (GONE when no open trade) -->
        <LinearLayout
            android:id="@+id/ll_trade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Row 1: Side + Symbol + Volume -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRADE"
                    android:textColor="#50FFD700"
                    android:textSize="8sp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_trade_side"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUY"
                    android:textColor="@color/price_up"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_trade_symbol"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=" XAUUSD"
                    android:textColor="#DDDDDD"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_trade_lots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.10 lots"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Row 2: Entry price + P&L -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@ "
                    android:textColor="#50FFD700"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_trade_entry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P&amp;L "
                    android:textColor="#50FFD700"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_trade_pnl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+$0.00"
                    android:textColor="@color/price_up"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- No trade / not connected message (VISIBLE by default) -->
        <LinearLayout
            android:id="@+id/ll_no_trade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRADE  "
                android:textColor="#50FFD700"
                android:textSize="8sp" />

            <TextView
                android:id="@+id/tv_no_trade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open app to connect cTrader"
                android:textColor="#60FFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-light" />

        </LinearLayout>

    </LinearLayout>

    <!-- Footer: timestamp + refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_updated"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#50FFFFFF"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_refresh"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:padding="3dp" />

    </LinearLayout>

</LinearLayout>
